# Dockerfile for Render deployment
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY package-render.json ./package.json

# Install dependencies
RUN npm ci --production

# Copy source code
COPY . .
COPY src/ ./src/
COPY client/ ./client/
COPY server/ ./server/
COPY shared/ ./shared/
COPY index.html ./
COPY vite.config.ts ./
COPY drizzle.config.ts ./

# Build application
RUN npm run build

# Expose port
EXPOSE 5000

# Start application
CMD ["npm", "start"]